# ── Server ──────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# URL do cliente (Vite dev ou domínio em prod)
CLIENT_URL=http://localhost:5173

# ── PostgreSQL (Supabase ou self-hosted) ─────────────────────────
# Supabase: Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres

# ── Redis ────────────────────────────────────────────────────────
# Local:   redis://localhost:6379
# Upstash: rediss://default:token@endpoint.upstash.io:6379
REDIS_URL=redis://localhost:6379

# ── Supabase (Auth + DB) ─────────────────────────────────────────
# Settings → API → Project URL e anon/service_role keys
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # NUNCA exponha no cliente

# ── JWT ──────────────────────────────────────────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_to_a_random_64_char_hex_string
JWT_EXPIRES_IN=8h

# ── Rate Limiting ─────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000   # 15 min
RATE_LIMIT_MAX=100

# ── Modo de Operação ──────────────────────────────────────────────
# 'cloud'  → somente cloud (padrão para novos estabelecimentos)
# 'hybrid' → cloud + fallback local
OPERATION_MODE=cloud

# Apenas para OPERATION_MODE=hybrid
# Endereço interno deste servidor local (LAN)
LOCAL_SERVER_LAN_URL=http://192.168.1.100:3001
# Intervalo do heartbeat com a cloud (ms)
HEARTBEAT_INTERVAL_MS=10000
# Cloud endpoint para sincronização
CLOUD_SYNC_URL=https://api.fila.io

# ── Client (Vite — prefixo VITE_ obrigatório) ────────────────────
# Copie este bloco para client/.env
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...   # chave pública, pode expor
VITE_SERVER_URL=http://localhost:3001
