PORT=3001
CLIENT_URL=http://localhost:5173

# Redis (filas rápidas em memória)
REDIS_URL=redis://localhost:6379

# PostgreSQL / Supabase (histórico persistente)
DATABASE_URL=postgresql://user:password@localhost:5432/fila_io

# JWT — gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_to_a_random_64_char_hex_string

# Rate limiting (15 minutos, 20 req máx por IP)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=20
